# Copy to .env and fill in. Defaults below target the TEST sandbox — no real requests are filed.

# Base URL of the Open311 web service.
#   TEST sandbox:  https://secure.toronto.ca/open311test/ws
#   PRODUCTION:    https://secure.toronto.ca/webwizard/ws
TORONTO_311_BASE_URL=https://secure.toronto.ca/open311test/ws

# Jurisdiction identifier (constant for Toronto).
TORONTO_311_JURISDICTION_ID=toronto.ca

# Required ONLY to POST a request (file_service_request). Request one from the City — see README.
TORONTO_311_API_KEY=
